# Database URL for MongoDB (production)
DATABASE_URL="mongodb+srv://<user>:<password>@<host>/<database>"

# Google Gemini API Key
GEMINI_API_KEY="<your-gemini-api-key>"

# Google Gemini API Keys (comma-separated, recommended for load balancing)
# Example: GEMINI_API_KEYS="key1,key2,key3"
GEMINI_API_KEYS=""

# Gemini model name (set to desired Gemini model, e.g. gemini-2.5-flash-lite)
GEMINI_MODEL="gemini-2.5-flash-lite"

# Gemini retry attempts across key pool (default: 3, max: 10)
GEMINI_MAX_ATTEMPTS=3

NEXT_PUBLIC_BASE_URL=http://localhost:3000
PORT=3000

# Enable automatic academic year & semester calculation when set (any non-empty value).
# Behavior:
# - ภาคเรียนที่ 1: 15 พฤษภาคม - 31 ตุลาคม ของปีปัจจุบัน
# - ภาคเรียนที่ 2: 1 พฤศจิกายน (ปีปัจจุบัน) - 30 มีนาคม (ปีถัดไป)
# - ภาคเรียนที่ 3: ยังไม่มีกำหนด
# Set to any non-empty value (e.g. true) to enable automatic selection in the UI.
NEXT_PUBLIC_AUTO_ACADEMIC=true

# Signature Names for PDF
NEXT_PUBLIC_SIGNATURE_REGISTRAR_NAME="นายสมชาย ใจดี"
NEXT_PUBLIC_SIGNATURE_ACADEMIC_HEAD_NAME="นางสาวพรทิพย์ เก่งงาน"
NEXT_PUBLIC_SIGNATURE_DIRECTOR_NAME="นายประเสริฐ ผู้อำนวยการ"